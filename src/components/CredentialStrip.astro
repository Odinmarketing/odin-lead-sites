---
// Credential strip: the spec-sheet trust device.
// Renders the proof points from the lead's company.credentials.
// HARD-CLAIM slot — these stay obvious placeholders unless the lead provided real values.
import type { Lead } from "../data/site";
interface Props { company: Lead["company"]; }
const { company } = Astro.props;
---

<div class="creds">
  <div class="container creds__inner">
    {company.credentials.map((c) => (
      <span class="creds__item">
        <span class="creds__dot" aria-hidden="true"></span>{c}
      </span>
    ))}
  </div>
</div>

<style>
  .creds { background: var(--c-ink); color: var(--c-paper); }
  .creds__inner {
    display: flex; flex-wrap: wrap; gap: var(--s-4);
    padding-block: 0.8rem; justify-content: center;
  }
  .creds__item {
    font-family: var(--f-mono); font-size: var(--t-xs);
    letter-spacing: .06em; text-transform: uppercase;
    display: inline-flex; align-items: center; gap: .5rem; color: #C9D2DB;
  }
  .creds__dot { width: 6px; height: 6px; border-radius: 50%; background: var(--c-ok); }
  @media (max-width: 640px) { .creds__inner { gap: var(--s-2) var(--s-3); } }
</style>
