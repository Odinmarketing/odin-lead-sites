---
import Base from "../../layouts/Base.astro";
import ContactCTA from "../../components/ContactCTA.astro";
import ProcessFlow from "../../components/ProcessFlow.astro";
import { leads } from "../../data/site";

export function getStaticPaths() {
  return leads.map((lead) => ({ params: { slug: lead.slug }, props: { lead } }));
}

const { lead } = Astro.props;
const h = lead.home;
const company = lead.company;
const base = `/${lead.slug}`;
---

<Base title="Home" description={company.tagline} lead={lead}>

  <!-- HERO. With a placed photo -> full-width banner (photo + dark scrim + overlaid copy,
       legible on any image). Without -> original left-weighted grid + spec panel. -->
  {lead.images?.hero ? (
    <section class="hero--banner">
      <div class="hero--banner__media">
        <img src={lead.images.hero} alt={`${company.name} — ${h.hero.eyebrow}`} width="1600" height="900" loading="eager" />
      </div>
      <div class="hero--banner__scrim"></div>
      <div class="container hero--banner__inner">
        <span class="eyebrow eyebrow--inv">{h.hero.eyebrow}</span>
        <h1 class="hero__h hero--banner__h">{h.hero.headline}</h1>
        <p class="hero__sub hero--banner__sub">{h.hero.sub}</p>
        <div class="hero__ctas">
          <a href={h.hero.primaryCta.href} class="btn btn--primary btn--lg">{h.hero.primaryCta.label}</a>
          <a href={h.hero.secondaryCta.href} class="hero__link hero--banner__link">{h.hero.secondaryCta.label} &rsaquo;</a>
        </div>
      </div>
    </section>
    <div class="container hero-trust" data-reveal>
      {h.heroTrust.map((t) => <span class="hero-trust__item mono">{t}</span>)}
    </div>
  ) : (
    <section class="hero">
      <div class="container hero__grid">
        <div class="hero__copy">
          <span class="eyebrow">{h.hero.eyebrow}</span>
          <h1 class="hero__h">{h.hero.headline}</h1>
          <p class="hero__sub">{h.hero.sub}</p>
          <div class="hero__ctas">
            <a href={h.hero.primaryCta.href} class="btn btn--primary btn--lg">{h.hero.primaryCta.label}</a>
            <a href={h.hero.secondaryCta.href} class="hero__link">{h.hero.secondaryCta.label} &rsaquo;</a>
          </div>
        </div>
        <aside class="hspec" aria-label="Key differentiators">
          <div class="hspec__bar">
            <span class="mono">SPEC SHEET</span>
            <span class="hspec__status"><span class="hspec__wire"></span>OPERATIONAL</span>
          </div>
          {h.heroSpec.map((s) => (
            <div class="hspec__row">
              <span class="hspec__label mono">{s.label}</span>
              <span class="hspec__val"><span data-count={s.value}>{s.value}</span> <span class="hspec__unit mono">{s.unit}</span></span>
            </div>
          ))}
        </aside>
      </div>
      <div class="container hero-trust" data-reveal>
        {h.heroTrust.map((t) => <span class="hero-trust__item mono">{t}</span>)}
      </div>
    </section>
  )}

  <!-- STATS: figure + unit, uppercase label above, one-line context beneath. -->
  <section class="section stats" data-reveal>
    <div class="container">
      <span class="eyebrow">{h.stats.eyebrow}</span>
      <h2 class="sec__h">{h.stats.heading}</h2>
      <div class="stats__grid" data-reveal-children>
        {h.stats.items.map((s) => (
          <div class="stat lift">
            <span class="stat__label mono">{s.label}</span>
            <span class="stat__fig"><span data-count={s.figure}>{s.figure}</span><span class="stat__unit"> {s.unit}</span></span>
            <p class="stat__ctx">{s.context}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROBLEM: supporting weight, benefit-driven subhead -->
  <section class="section" data-reveal>
    <div class="container">
      <span class="eyebrow">{h.problems.eyebrow}</span>
      <h2 class="sec__h prob__h">{h.problems.heading}</h2>
      <div class="prob__grid" data-reveal-children>
        {h.problems.items.map((p) => (
          <div class="prob__card lift">
            <span class="prob__label mono">{p.label}</span>
            <p>{p.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CAPABILITY LEDGER: the VISUAL PEAK. Dark, large type, generous spacing. -->
  <section class="section section--dark ledger-sec" id="capabilities" data-reveal>
    <div class="container">
      <span class="eyebrow">{h.ledger.eyebrow}</span>
      <h2 class="ledger__heading">{h.ledger.heading}</h2>
      {lead.images?.capabilities && (
        <div class="sec-img sec-img--dark">
          <img src={lead.images.capabilities} alt={`${company.name} — ${h.ledger.heading}`} width="1200" height="500" loading="lazy" />
        </div>
      )}
      <div class="ledger" data-reveal-children>
        {h.ledger.rows.map((r) => (
          <div class="ledger__row">
            <span class="ledger__no mono">{r.spec}</span>
            <div class="ledger__body">
              <h3 class="ledger__cap">{r.capability}</h3>
              <p>{r.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROCESS: SUPPORTING weight. Smaller type, tighter density. Detail, not climax. -->
  <section class="section--tight proc-sec" id="process" data-reveal>
    <div class="container">
      <span class="eyebrow">{h.process.eyebrow}</span>
      <h2 class="proc__h">{h.process.heading}</h2>
      <ol class="proc" data-reveal-children>
        {h.process.steps.map((s) => (
          <li class="proc__step">
            <span class="proc__n mono">{s.n}</span>
            <h3 class="proc__t">{s.title}</h3>
            <p>{s.text}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- SCROLL-DRIVEN PROCESS DIAGRAM (home only, adjacent to process) -->
  <ProcessFlow flow={h.flow} />

  <!-- Full-bleed operations banner (premium stock, placed by fetch-images.js) -->
  {lead.images?.operations && (
    <section class="imgband" data-reveal>
      <img src={lead.images.operations} alt={`${company.name} operations`} width="1600" height="520" loading="lazy" />
    </section>
  )}

  <!-- CTA ESCALATION level 2 (medium): request a quote -->
  <section class="section--tight" data-reveal>
    <div class="container ctaband">
      <h2 class="ctaband__h">{h.ctaMid.heading}</h2>
      <a href={h.ctaMid.href} class="btn btn--primary btn--lg">{h.ctaMid.label}</a>
    </div>
  </section>

  <!-- TRUST BAND (home only): grayscale client logos + cert badges. Hard-claim. -->
  <section class="section--tight trustband" data-reveal>
    <div class="container">
      <p class="trustband__h center">{h.trustBand.heading}</p>
      <div class="trustband__logos" data-reveal-children>
        {h.trustBand.logos.map((l) => <span class="logo-slot">{l}</span>)}
      </div>
      <div class="trustband__certs">
        {h.trustBand.certs.map((c) => <span class="cert-slot mono">{c}</span>)}
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS: credibility-rich cards (quote, name, title, company, result). Hard-claim. -->
  <section class="section" data-reveal>
    <div class="container">
      <span class="eyebrow">{h.proof.eyebrow}</span>
      <h2 class="sec__h">{h.proof.heading}</h2>
      <div class="quotes" data-reveal-children>
        {h.proof.testimonials.map((t) => (
          <figure class="quote lift">
            <blockquote>“{t.quote}”</blockquote>
            <figcaption class="quote__foot">
              <div class="quote__id">
                <strong>{t.name}</strong>
                <span class="quote__role">{t.title}, {t.company}</span>
              </div>
              <span class="quote__result mono">{t.result}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section--tight" data-reveal>
    <div class="container faq">
      <div class="faq__head">
        <span class="eyebrow">{h.faq.eyebrow}</span>
        <h2 class="sec__h">{h.faq.heading}</h2>
      </div>
      <div class="faq__list">
        {h.faq.items.map((f) => (
          <details class="faq__item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA ESCALATION level 3 (high): final hard close, static CTA (tel:/mailto:). -->
  <section class="section section--dark" data-reveal>
    <div class="container">
      <ContactCTA company={company} cta={h.endCta} />
    </div>
  </section>

</Base>

<style>
  .sec__h { margin-block: var(--s-2) var(--s-4); max-width: 26ch; }

  /* HERO: left-weighted, faint drifting technical grid behind it */
  .hero { position: relative; overflow: hidden; padding-block: var(--s-7) var(--s-4); border-bottom: 1px solid var(--c-line); }
  .hero::before {
    content: ""; position: absolute; inset: -40px; z-index: 0; pointer-events: none;
    background-image:
      repeating-linear-gradient(0deg, rgba(20,20,19,.045) 0 1px, transparent 1px 40px),
      repeating-linear-gradient(90deg, rgba(20,20,19,.045) 0 1px, transparent 1px 40px);
    animation: heroDrift 20s linear infinite alternate;
  }
  @keyframes heroDrift { from { transform: translate(0,0); } to { transform: translate(20px,20px); } }
  .hero > .container { position: relative; z-index: 1; }
  .hero__grid { display: grid; grid-template-columns: 1.35fr .9fr; gap: var(--s-5); align-items: center; }
  .hero__h { margin-block: var(--s-2) var(--s-3); max-width: 14ch; }
  .hero__sub { font-size: var(--t-lg); max-width: 48ch; }
  .hero__ctas { display: flex; gap: var(--s-3); margin-top: var(--s-4); flex-wrap: wrap; align-items: center; }
  .hero__link { font-family: var(--f-display); font-weight: 600; color: var(--c-ink); min-height: 44px; display: inline-flex; align-items: center; }
  .hero__link:hover { color: var(--c-accent); }

  /* HERO SPEC PANEL (default) */
  .hspec { background: var(--c-ink); color: var(--c-paper); border-radius: var(--radius); padding: var(--s-3); box-shadow: var(--shadow); }
  .hspec__bar { display: flex; justify-content: space-between; align-items: center; font-size: var(--t-xs); letter-spacing: .12em; color: #B8C2CC; padding-bottom: var(--s-2); border-bottom: 1px solid rgba(255,255,255,.12); }
  .hspec__status { display: flex; align-items: center; gap: .4rem; color: var(--c-ok); }
  .hspec__wire { width: 7px; height: 7px; border-radius: 50%; background: var(--c-ok); box-shadow: 0 0 0 3px rgba(46,125,91,.25); }
  .hspec__row { display: flex; justify-content: space-between; align-items: baseline; gap: var(--s-2); padding: var(--s-2) 0; border-bottom: 1px solid rgba(255,255,255,.08); }
  .hspec__label { font-size: var(--t-xs); color: #B8C2CC; letter-spacing: .08em; }
  .hspec__val { font-family: var(--f-display); font-weight: 700; color: #fff; font-size: var(--t-lg); }
  .hspec__unit { font-size: var(--t-xs); color: var(--c-accent); font-weight: 500; }

  /* HERO VISUAL (alternative) */
  .hvisual { display: grid; place-items: center; min-height: 260px; background: var(--c-surface); border: 1px dashed var(--c-line); border-radius: var(--radius); color: var(--c-muted); font-family: var(--f-mono); }
  /* HERO BANNER — full-width photo + dark scrim + overlaid copy (legible on any image) */
  .hero--banner { position: relative; overflow: hidden; min-height: clamp(420px, 56vh, 600px); display: grid; align-items: center; border-bottom: 1px solid var(--c-line); }
  .hero--banner__media { position: absolute; inset: 0; z-index: 0; }
  .hero--banner__media img { width: 100%; height: 100%; object-fit: cover; }
  .hero--banner__scrim { position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(90deg, rgba(12,14,16,.85) 0%, rgba(12,14,16,.66) 40%, rgba(12,14,16,.20) 75%, rgba(12,14,16,0) 100%); }
  .hero--banner__inner { position: relative; z-index: 2; padding-block: var(--s-7); max-width: 62ch; }
  .hero--banner__h { color: #fff; margin-block: var(--s-2) var(--s-3); max-width: 16ch; }
  .hero--banner__sub { color: rgba(255,255,255,.92); font-size: var(--t-lg); max-width: 46ch; }
  .eyebrow--inv { color: rgba(255,255,255,.82); }
  .hero--banner__link { color: #fff; }
  .hero--banner__link:hover { color: var(--c-accent); }

  /* In-section image (capabilities) */
  .sec-img { border-radius: var(--radius); overflow: hidden; margin-block: var(--s-4) var(--s-2); }
  .sec-img img { display: block; width: 100%; height: auto; aspect-ratio: 24 / 9; object-fit: cover; }
  .sec-img--dark { border: 1px solid rgba(255,255,255,.14); }

  /* Full-bleed operations banner (spans full viewport width) */
  .imgband { width: 100%; height: clamp(220px, 30vw, 420px); overflow: hidden; }
  .imgband img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* Thin trust strip */
  .hero-trust { display: flex; flex-wrap: wrap; gap: var(--s-3); margin-top: var(--s-4); padding-top: var(--s-3); border-top: 1px solid var(--c-line); }
  .hero-trust__item { font-size: var(--t-xs); letter-spacing: .08em; color: var(--c-muted); text-transform: uppercase; display: inline-flex; align-items: center; }
  .hero-trust__item:not(:first-child)::before { content: "·"; margin-right: var(--s-3); color: var(--c-line); }

  /* STATS */
  .stats__grid { display: grid; grid-template-columns: repeat(3,1fr); gap: var(--s-3); margin-top: var(--s-3); }
  .stat { background: var(--c-surface); border: 1px solid var(--c-line); border-radius: var(--radius); padding: var(--s-4); }
  .stat__label { display: block; font-size: var(--t-xs); letter-spacing: .14em; color: var(--c-primary); text-transform: uppercase; margin-bottom: .5rem; }
  .stat__fig { font-family: var(--f-display); font-size: var(--t-3xl); font-weight: 700; color: var(--c-ink); line-height: 1; display: block; }
  .stat__unit { font-size: var(--t-lg); color: var(--c-accent); font-weight: 600; }
  .stat__ctx { margin-top: var(--s-2); font-size: var(--t-sm); color: var(--c-muted); }

  /* PROBLEM (supporting) */
  .prob__h { max-width: 24ch; }
  .prob__grid { display: grid; grid-template-columns: repeat(3,1fr); gap: var(--s-3); }
  .prob__card { background: var(--c-surface); border: 1px solid var(--c-line); border-left: 3px solid var(--c-accent); border-radius: var(--radius); padding: var(--s-3); }
  .prob__label { font-size: var(--t-xs); letter-spacing: .14em; color: var(--c-primary); display: block; margin-bottom: .5rem; }

  /* LEDGER (VISUAL PEAK) — larger type, generous spacing */
  .ledger-sec { padding-block: var(--s-7); }
  .ledger__heading { font-size: var(--t-4xl); margin-block: var(--s-2) var(--s-5); max-width: 18ch; }
  .ledger { border-top: 1px solid rgba(255,255,255,.14); }
  .ledger__row { display: grid; grid-template-columns: 88px 1fr; gap: var(--s-4); padding: var(--s-4) 0; border-bottom: 1px solid rgba(255,255,255,.1); align-items: start; }
  .ledger__no { color: var(--c-accent); font-size: var(--t-2xl); }
  .ledger__cap { color: #fff; margin-bottom: .5rem; font-size: var(--t-xl); }
  .ledger__body p { font-size: var(--t-lg); }

  /* PROCESS (SUPPORTING) — smaller, tighter density */
  .proc-sec { padding-block: var(--s-5); }
  .proc__h { font-size: var(--t-xl); margin-block: var(--s-1) var(--s-3); }
  .proc { list-style: none; padding: 0; display: grid; grid-template-columns: repeat(4,1fr); gap: var(--s-2); }
  .proc__step { border-top: 2px solid var(--c-line); padding-top: var(--s-1); position: relative; }
  .proc__step::before { content: ""; position: absolute; top: -2px; left: 0; width: 28px; height: 2px; background: var(--c-accent); }
  .proc__n { font-size: var(--t-lg); color: var(--c-primary); font-weight: 500; display: block; }
  .proc__t { font-size: var(--t-base); margin-block: .25rem .35rem; }
  .proc__step p { font-size: var(--t-sm); color: var(--c-muted); }

  /* MID CTA BAND */
  .ctaband { display: flex; justify-content: space-between; align-items: center; gap: var(--s-3); flex-wrap: wrap; background: var(--c-surface); border: 1px solid var(--c-line); border-left: 3px solid var(--c-accent); border-radius: var(--radius); padding: var(--s-4); }
  .ctaband__h { font-size: var(--t-xl); max-width: 30ch; margin: 0; }

  /* TRUST BAND */
  .trustband__h { color: var(--c-muted); font-size: var(--t-sm); margin-bottom: var(--s-3); }
  .trustband__logos { display: grid; grid-template-columns: repeat(5,1fr); gap: var(--s-2); }
  .logo-slot { display: grid; place-items: center; height: 64px; border: 1px solid var(--c-line); border-radius: var(--radius); background: var(--c-surface); color: var(--c-muted); font-family: var(--f-mono); font-size: var(--t-xs); filter: grayscale(1); }
  .trustband__certs { display: flex; justify-content: center; gap: var(--s-3); margin-top: var(--s-3); flex-wrap: wrap; }
  .cert-slot { font-size: var(--t-xs); letter-spacing: .08em; color: var(--c-muted); border: 1px dashed var(--c-line); border-radius: var(--radius); padding: .4rem .7rem; text-transform: uppercase; }

  /* TESTIMONIALS */
  .quotes { display: grid; grid-template-columns: 1fr 1fr; gap: var(--s-3); margin-top: var(--s-3); }
  .quote { background: var(--c-surface); border: 1px solid var(--c-line); border-radius: var(--radius); padding: var(--s-4); }
  .quote blockquote { font-family: var(--f-display); font-size: var(--t-lg); color: var(--c-ink); line-height: 1.4; margin: 0; }
  .quote__foot { margin-top: var(--s-3); padding-top: var(--s-2); border-top: 1px solid var(--c-line); display: flex; justify-content: space-between; align-items: flex-end; gap: var(--s-2); flex-wrap: wrap; }
  .quote__id strong { display: block; color: var(--c-ink); }
  .quote__role { color: var(--c-muted); font-size: var(--t-sm); }
  .quote__result { font-size: var(--t-xs); color: var(--c-accent); border: 1px solid var(--c-accent); border-radius: var(--radius); padding: .25rem .5rem; }

  /* FAQ */
  .faq { display: grid; grid-template-columns: 1fr 1.4fr; gap: var(--s-5); }
  .faq__item { border-bottom: 1px solid var(--c-line); padding: var(--s-2) 0; }
  .faq__item summary { font-family: var(--f-display); font-weight: 600; font-size: var(--t-lg); cursor: pointer; list-style: none; display: flex; justify-content: space-between; gap: var(--s-2); min-height: 44px; align-items: center; }
  .faq__item summary::after { content: "+"; color: var(--c-accent); font-weight: 400; }
  .faq__item[open] summary::after { content: "–"; }
  .faq__item p { margin-top: .6rem; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .hero__grid { grid-template-columns: 1fr; }   /* spec panel stacks below headline */
    /* full-width text on mobile -> stronger vertical scrim for legibility */
    .hero--banner__scrim { background: linear-gradient(180deg, rgba(12,14,16,.5) 0%, rgba(12,14,16,.82) 100%); }
    .hero--banner__inner { max-width: none; }
    .prob__grid { grid-template-columns: 1fr; }
    .proc { grid-template-columns: repeat(2,1fr); } /* 4 -> 2 */
    .trustband__logos { grid-template-columns: repeat(3,1fr); }
    .quotes { grid-template-columns: 1fr; }
    .faq { grid-template-columns: 1fr; gap: var(--s-3); }
  }
  @media (max-width: 560px) {
    .stats__grid { grid-template-columns: 1fr; }   /* 3 -> 1, full-width figures */
    .proc { grid-template-columns: 1fr; }          /* 2 -> 1 */
    .trustband__logos { grid-template-columns: repeat(2,1fr); }
  }
</style>
